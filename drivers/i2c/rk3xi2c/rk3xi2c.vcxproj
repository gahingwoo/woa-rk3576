<?xml version="1.0" encoding="utf-8"?>
<!--
  WDK / EWDK KMDF driver project for rk3xi2c (Windows on ARM64).

  Build (EWDK developer prompt, after LaunchBuildEnv.cmd):
      msbuild rk3xi2c.vcxproj /p:Configuration=Release /p:Platform=ARM64

  If MSBuild cannot resolve the WDK targets, recreate from the VS "Kernel Mode
  Driver, Empty (KMDF)" template and add hw.c / driver.c / spb.c + the headers;
  the settings below mirror that template.
-->
<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|ARM64">
      <Configuration>Debug</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|ARM64">
      <Configuration>Release</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{C4D6E2F3-5A7B-4C9D-8E0F-2A3B4C5D6E7F}</ProjectGuid>
    <TemplateGuid>{dd38f7fc-d7bd-488b-9242-7d8754cde80d}</TemplateGuid>
    <RootNamespace>rk3xi2c</RootNamespace>
    <MinimumVisualStudioVersion>14.0</MinimumVisualStudioVersion>
    <Configuration>Release</Configuration>
    <Platform Condition="'$(Platform)' == ''">ARM64</Platform>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <TargetVersion>Windows10</TargetVersion>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>KMDF</DriverType>
    <DriverTargetPlatform>Universal</DriverTargetPlatform>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <KMDF_VERSION_MAJOR>1</KMDF_VERSION_MAJOR>
    <KMDF_VERSION_MINOR>33</KMDF_VERSION_MINOR>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>true</TreatWarningAsError>
      <PreprocessorDefinitions>_KERNEL_MODE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <!-- spbcx.lib provides the SpbCx framework imports. -->
      <AdditionalDependencies>$(DDK_LIB_PATH)spbcx.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <Inf>
      <SpecifyArchitecture>true</SpecifyArchitecture>
      <Architecture>arm64</Architecture>
    </Inf>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="driver.c" />
    <ClCompile Include="spb.c" />
    <ClCompile Include="hw.c" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="rk3xi2c.h" />
    <ClInclude Include="rk3xi2c_regs.h" />
  </ItemGroup>

  <ItemGroup>
    <Inf Include="rk3xi2c.inf" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
